version: "3.3"
services:

  ambivalent_mysql:
    container_name: ambivalent_mysql
    build:
      context: g-mysql
      dockerfile: Dockerfile
      args:
        - MYSQL_ROOT_PASSWORD={{ golly_wiki_mysql_password }}
    restart: unless-stopped
    command: --performance-schema=0 --innodb-buffer-pool-size=128M --max-connections=50
    volumes:
      - "ambivalent_mysql_data:/var/lib/mysql"
    logging:
      driver: "json-file"
      options:
        max-size: 2m
        max-file: "10"
    deploy:
      resources:
        limits:
          cpus: '0.50'
          memory: 384M
    environment:
      - MYSQL_ROOT_PASSWORD={{ golly_wiki_mysql_password }}
      - MYSQL_DATABASE=wikidb
      - MYSQL_USER=wikiuser
      - MYSQL_PASSWORD={{ golly_wiki_mysql_wikiuser_password }}
    networks:
      - backend

  ambivalent_mw:
    container_name: ambivalent_mw
    build: g-mediawiki
    volumes:
      - "ambivalent_mw_data:/var/www/html"
    logging:
      driver: "json-file"
      options:
        max-size: 2m
        max-file: "10"
    deploy:
      resources:
        limits:
          cpus: '0.80'
          memory: 512M
    environment:
      - MEDIAWIKI_SITE_SERVER=https://wiki.golly.life
      - MEDIAWIKI_SECRETKEY={{ golly_wiki_mw_secretkey }}
      - MYSQL_HOST=ambivalent_mysql
      - MYSQL_DATABASE=wikidb
      - MYSQL_USER=wikiuser
      - MYSQL_PASSWORD={{ golly_wiki_mysql_wikiuser_password }}
    depends_on:
      - ambivalent_mysql
    networks:
      - frontend
      - backend

  ambivalent_nginx:
    container_name: ambivalent_nginx
    restart: always
    image: nginx:1.25
    command: /bin/bash -c "nginx -g 'daemon off;'"
    volumes:
      - "./g-nginx/conf.d:/etc/nginx/conf.d:ro"
      - "./g-nginx/robots:/var/www/robots:ro"
      - "/etc/localtime:/etc/localtime:ro"
      - "/etc/letsencrypt:/etc/letsencrypt"
    logging:
      driver: "json-file"
      options:
        max-size: 2m
        max-file: "10"
    depends_on:
      - ambivalent_mw
    ports:
      - "80:80"
      - "443:443"
    networks:
      - frontend


networks:
  # `frontend` is shared with the golly ai-slackbots stack (mediawiki-mcp-golly,
  # wiki-golly-bot, golly-personas-bot attach to it as `pod-golly-wiki_frontend`).
  # Mark it external here so `docker-compose down` never tries to remove the
  # network out from under those containers. Bootstrap: the pod-golly-wiki.service
  # unit ensures the network exists before `up`.
  frontend:
    external: true
    name: pod-golly-wiki_frontend
  backend:

volumes:
  ambivalent_mysql_data:
  ambivalent_mw_data:
